From 1d8d40994565491a1dba0c7563e742e0b9c98e8b Mon Sep 17 00:00:00 2001
From: Mark Vainomaa <mikroskeem@mikroskeem.eu>
Date: Wed, 18 Jul 2018 20:23:03 +0300
Subject: [PATCH] Copy license files into jar


diff --git a/proxy/pom.xml b/proxy/pom.xml
index f1fadd9d..315f5f91 100644
--- a/proxy/pom.xml
+++ b/proxy/pom.xml
@@ -132,4 +132,26 @@
             <scope>runtime</scope>
         </dependency>
     </dependencies>
+
+    <!-- Waterfall start - copy license files into jar -->
+    <build>
+        <resources>
+            <resource>
+                <directory>src/main/resources</directory>
+            </resource>
+            <resource>
+                <directory>../</directory>
+                <includes>
+                    <include>LICENSE</include>
+                </includes>
+            </resource>
+            <resource>
+                <directory>../../</directory>
+                <includes>
+                    <include>LICENSE.txt</include>
+                </includes>
+            </resource>
+        </resources>
+    </build>
+    <!-- Waterfall end -->
 </project>
-- 
